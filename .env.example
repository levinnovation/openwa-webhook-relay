# OpenWA → Relay: HMAC secret for webhook signature verification
# Must match the "secret" field set when registering the webhook in OpenWA
OPENWA_WEBHOOK_SECRET=your-shared-secret-here

# Which workspace (tenant) in the lev-agent-demo backend to route messages to
WORKSPACE_ID=acme-corp

# URL of the lev-agent-demo backend (Railway deployment)
BACKEND_URL=https://lev-agent-demo-production.up.railway.app

# API key for authenticating with the backend
# (required because /webhooks/execute/* is not a public path)
BACKEND_API_KEY=sk-xxx

# Target flow to execute on the backend (don't change unless custom flow)
TARGET_FLOW=inbound_lead_flow

# Execution mode: deterministic (flow) or cognitive (crew)
TARGET_MODE=deterministic
